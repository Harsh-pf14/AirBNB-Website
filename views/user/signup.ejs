<% layout("/layouts/boilerplate") %>
<body>
    <div class="row">
        <div class="col-10 col-md-8 mx-auto">
            <h1 class="mb-4 mt-5">SignUp on AirBNB</h1>
            <form method="POST" action="/signup" class="needs-validation" novalidate>      <!--novalidate removes default HTML5 validation, allowing us to use Bootstrap's custom validation styles -->
                <div class="form-group mb-3">
                    <label for="username" class="form-label"><b>Username:</b></label>
                    <input type="text" id="username" placeholder="Enter username" name="user[username]" required class="form-control">
                    <div class="invalid-feedback">
                        Please enter a username.
                    </div>
                </div>

                <div class="form-group mb-3">
                    <label for="email" class="form-label"><b>Email:</b></label>
                    <input type="email" id="email" placeholder="Enter email" name="user[email]" required class="form-control">
                    <div class="invalid-feedback">
                        Please enter a valid email.
                    </div>
                </div>

                <div class="form-group mb-3">
                    <label for="password" class="form-label"><b>Password:</b></label>
                    <input type="password" id="password" placeholder="Enter password" name="user[password]" required class="form-control">
                    <div class="invalid-feedback">
                        Please enter a password.
                    </div>
                </div>

                <div class="d-grid d-md-block mt-4 mb-5 mb-md-0">
                    <button type="submit" class="btn btn-success btn-signup">Sign Up</button>
                </div>
            </form>
        </div>
    </div>
</body>