<% layout("/layouts/boilerplate") %>
    <div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 row-cols-1 g-4 mt-4">
        <% for (let elem of allListings) { %>
            <a href="/listings/<%= elem._id %>" class = "card-link">
                <div class="card col">
                    <img src="<%= elem.image.url %>" class="card-img-top" alt="<%= elem.title %>">
                    <div class="card-img-overlay"></div>
                    <div class="card-body">
                        <p class="card-text">
                            <b><%= elem.title %></b><br>
                            ₹ <%= elem.price.toLocaleString('en-IN') %> / night
                        </p>
                    </div>
                </div>
            </a>
        <% } %>
    </div>