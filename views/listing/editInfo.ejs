<% layout("/layouts/boilerplate") %>
<body>
    <div class="row"> 
        <div class="col-10 col-md-8 mx-auto">
            <h1 class="mb-4 mt-5"> Edit Your Listing </h1>
            <form method="POST" action="/listings/<%= compData._id %>?_method=PUT"  
                    class="needs-validation" novalidate enctype="multipart/form-data">     <!-- PUT overrides POST -->
                <div class="form-group mb-3">
                    <label for="title" class="form-label"><b>Title:</b></label>
                    <input type="text" value = "<%= compData.title %>" name="listing[title]" class="form-control" required>
                    <div class="invalid-feedback">
                        Please enter a title.
                    </div>
                </div>

                <div class="form-group mb-3">
                    <label for="description" class="form-label"><b>Description:</b></label>
                    <textarea name="listing[description]" rows="4" cols="50" class="form-control" required><%= compData.description %></textarea>
                    <div class="invalid-feedback">
                        Please provide a description.
                    </div>
                </div>

                <div class="form-group mb-3">
                    <label for="imageUrl" class="form-label"><b>Image:</b></label><br>
                    <img src="<%= compData.image.url %>" alt="Listing Image" class="img-fluid rounded shadow-sm mb-3" style="max-width: 200px;">
                    <input type="file" name="listing[image]" id="imageUrl"
                        class="form-control" accept=".jpg,.jpeg,.png">
                    <div class="invalid-feedback">
                        Please upload an image.
                    </div>
                </div>

                <div class="row">
                    <div class="form-group mb-3 col-md-5">
                        <label for="price" class="form-label"><b>Price (₹):</b></label>
                        <input type="number" value = "<%= compData.price %>" id="price" name="listing[price]" required class="form-control">
                        <div class="invalid-feedback">
                            Please enter a valid price.
                        </div>
                    </div>

                    <div class="form-group mb-3 col-md-7">
                        <label for="country" class="form-label"><b>Country:</b></label>
                        <input type="text" value = "<%= compData.country %>" id="country" name="listing[country]" class="form-control" required>
                        <div class="invalid-feedback">
                            Please enter a country.
                        </div>
                    </div>
                </div>

                <div class="form-group mb-3">
                    <label for="location" class="form-label"><b>Location:</b></label>
                    <input type="text" value = "<%= compData.location %>" id="location" name="listing[location]" required class="form-control">
                    <div class="invalid-feedback">
                        Please enter a location.
                    </div>
                </div>

                <div class="d-grid d-md-block mt-4 mb-5 mb-md-0">
                    <button type="submit" class="btn btn-primary">Edit Information</button>
                </div>
            </form>
        </div>
    </div>

    <script src="/js/imageValidation.js"></script>
</body>