<% layout("/layouts/boilerplate") %>
    <br><br>
    <div class="row">
        <div class="col-10 col-md-8 mx-auto mt-4">
            <h2 class="ms-4"><b><%= compData.title %></b></h2>
        </div>
        <div class="card col-10 col-md-6 mx-auto">
            <img src="<%= compData.image.url %>" class="card-img-top show-img" alt="<%= compData.title %>">
            <div class="card-body mt-3">
                <p class="card-text">
                    <i class="bi bi-person-fill"></i> <strong><%= compData.owner.username %></strong><br>
                    <%= compData.description %><br>
                    <%= compData.location %><br>
                    <%= compData.country %><br>
                    ₹ <%= compData.price.toLocaleString('en-IN') %>
                </p>

                <% if (currUser && currUser._id.equals(compData.owner._id)) { %>
                <div class="btns d-flex">
                    <div>
                        <form method = "GET" action="/listings/<%= compData._id %>/edit">
                            <button class="btn btn-primary mt-3 btn-sm">Edit Information</button>
                        </form>
                    </div>
                    <div>
                        <form method = "POST" action="/listings/<%= compData._id %>?_method=DELETE" 
                            onsubmit="return confirm('Are you sure you want to delete this listing?')">
                            <button class="btn btn-danger mt-3 btn-sm">Delete Listing</button>
                        </form>
                    </div>
                </div>
                <% } %>
            </div>
        </div>

        <!-- Add Review Section -->
        <div class="col-10 col-md-8 mx-auto mt-4 mb-5">
            <% if (currUser && 
                   !hasReviewed && 
                   compData.owner._id.toString() !== currUser._id.toString()) { %>
            <hr>
            <h3>Leave a Review</h3>

            <form method="POST" action="/listings/<%= compData._id %>/reviews" class="needs-validation" novalidate>
                <div class="mb-3 mt-3">
                    <label for="rating" class="form-label">
                        Rating:
                    </label>

                    <fieldset class="starability-grow">
                        <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked aria-label="No rating." />
                        <input type="radio" id="first-rate1" name="review[rating]" value="1" />
                        <label for="first-rate1" title="Terrible">1 star</label>
                        <input type="radio" id="first-rate2" name="review[rating]" value="2" />
                        <label for="first-rate2" title="Not good">2 stars</label>
                        <input type="radio" id="first-rate3" name="review[rating]" value="3" />
                        <label for="first-rate3" title="Average">3 stars</label>
                        <input type="radio" id="first-rate4" name="review[rating]" value="4" />
                        <label for="first-rate4" title="Very good">4 stars</label>
                        <input type="radio" id="first-rate5" name="review[rating]" value="5" />
                        <label for="first-rate5" title="Amazing">5 stars</label>
                    </fieldset>
                </div>

                <div class="mb-3 mt-3">
                    <label for="comment" class="form-label">Your Review</label>

                    <textarea
                        class="form-control"
                        id="comment"
                        name="review[comment]"
                        rows="3"
                        required
                    ></textarea>

                    <div class="invalid-feedback">
                        Please enter a review.
                    </div>
                </div>

                <button type="submit" class="btn btn-signup btn-sm">
                    Submit Review
                </button>
            </form>
            <% } %>

            <br>
            <hr class="my-4">
            <h3>Reviews</h3>
            <% if (compData.reviews.length === 0) { %>
                <p class="text-muted mt-3">No reviews yet.</p>
            <% } else { %>
                <div class="row justify-content-center">
                    <% compData.reviews.forEach(review => { %>
                        <div class="card col-12 col-md-5 ms-md-3 mb-3 brd">
                            <div class="card-body p-3 d-flex flex-column h-100">
                                <p class="fw-bold text-dark mb-2">
                                    <i class="bi bi-person-circle me-1"></i>
                                    <%= review.owner.username %>
                                </p>
                                <div class="mb-2">
                                    <p class="starability-result card-text" data-rating=<%= review.rating %>>
                                    </p>
                                </div>
                                <p class="card-text flex-grow-1">
                                    <%= review.comment %>
                                </p>

                                <% if (currUser && currUser._id.equals(review.owner._id)) { %>
                                    <form method="POST" action="/listings/<%= compData._id %>/reviews/<%= review._id %>?_method=DELETE"
                                        onsubmit="return confirm('Delete this review?')">
                                        <button class="btn btn-danger btn-sm">
                                            Delete
                                        </button>
                                    </form>
                                <% } %>
                            </div>
                        </div>
                    <% }) %>
                </div>
            <% } %>
        </div>
    </div>